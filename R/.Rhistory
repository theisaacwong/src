if(bool_1==TRUE | bool_2==TRUE){return(0.5)}
return(0)
}
if(bool_1==TRUE & bool_2==TRUE){
return(1)
}
if(bool_1==TRUE | bool_2==TRUE){
return(0.5)
}
return(0)
}) %>% unlist
srt(df03$accuracy)
df_rval <- data.frame(name = curr_gene,
both = sum(df03$accuracy==1),
one = sum(df03$accuracy==0.5),
none = sum(df03$accuracy==0))
df_rval <- data.frame(GENE = curr_gene %>% str_to_upper,
both = sum(df03$accuracy==1) %>% paste0(., " (", round(100*sum(df03$accuracy==1)/nrow(df03),2),"%)"),
one = sum(df03$accuracy==0.5)%>% paste0(., " (", round(100*sum(df03$accuracy==0.5)/nrow(df03),2),"%)"),
none = sum(df03$accuracy==0)%>% paste0(., " (", round(100*sum(df03$accuracy==0)/nrow(df03),2),"%)"),
n = nrow(df03)
)
df_rval <- data.frame(GENE = curr_gene %>% str_to_upper,
both = paste0(round(100*sum(df03$accuracy==1)/nrow(df03),1),"%"),
one  = paste0(round(100*sum(df03$accuracy==0.5)/nrow(df03),1),"%"),
none = paste0(round(100*sum(df03$accuracy==0)/nrow(df03),1),"%"),
n = nrow(df03)
)
return(df_rval)
})  %>% do.call(rbind, .)
