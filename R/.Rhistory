df_rval$notes <- lapply(seq_down(df_rval), function(x){
if(df_rval$sensitivity[x] %>% is.nan){
if(lu(list_by_variant[[df_rval$name[x]]]$ref_gt)==1 & lu(list_by_variant[[df_rval$name[x]]]$ltgt_to_gt)==1 ){
return("only 0|0 in VCF")
}
}
if(df_rval$precision[x] %>% is.nan){
if(lu(list_by_variant[[df_rval$name[[x]]]]$ltgt_to_gt)==1 & all(list_by_variant[[df_rval$name[[x]]]]$ltgt_to_gt=="0|0")){
return("locityper only called 0|0")
}
}
return("")
}) %>% unlist
df_rval$notes <- lapply(seq_down(df_rval), function(x){
n_10 <- sum(df11$has_cram[df11$variant==df_rval$name[x] & df11$gt=="1|0"])
rval <- paste0(n_10, ", ", df_rval$notes[x])
return(rval)
}) %>% unlist
df_rval <- df_rval[order(df_rval$F1, decreasing = TRUE), ]
write.table(df01, "C:/docs/aou/locityper/svs_sr/summary_final_batch.tsv", sep="\t", col.names = TRUE, row.names = FALSE, quote=FALSE)
write.table(df_rval, "C:/docs/aou/locityper/svs_sr/summary_stats_by_loci_final_batch.tsv", sep="\t", col.names = TRUE, row.names = FALSE, quote=FALSE)
