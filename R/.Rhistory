files <- list.files("C:/docs/aou/locityper/manual_fastas/results3/results/", full.names = TRUE, recursive = TRUE, pattern = ".csv")
df01 <- lapply(files, function(x){
curr_sample <- x %>% str_extract("(?<=gts.).*(?=.csv)")
df_temp <- fread(x) %>% as.data.frame()
df_temp$sample <- curr_sample
return(df_temp)
}) %>% do.call(rbind, .)
df01$ref_gt <- lapply(seq_down(df01), function(x){
curr_var <- df01$locus[x]
curr_sample <- df01$sample[x]
if(!variantToSamples$containsKey(curr_var)){return("NA")}
if(variantToSamples$get(curr_var)$containsKey(curr_sample)){
return(variantToSamples$get(curr_var)$get(curr_sample))
} else {
return("NA")
}
}) %>% unlist
df01 <- df01[df01$ref_gt != "NA", ]
df01 <- df01[!grepl("\\.", df01$ref_gt), ]
df01$ltgt_to_gt <- lapply(seq_down(df01), function(x){
rvals <- lapply(unlist(df01$genotype[x] %>% str_split(",")), function(gt){
rval <- "ooblets"
if(gt=="GRCh38"){
rval <- "0"
} else {
which_hap  <- gt %>% str_extract("(?<=\\.).$") %>% as.numeric()
which_samp <- gt %>% str_extract(".*(?=..$)")
# print(paste0(gt,  ": ", which_samp, " ::: ", which_hap))
rval <- unlist(str_split(variantToSamples$get(df01$locus[x])$get(which_samp), "\\|"))[which_hap]
}
return(rval)
}) %>% unlist %>% paste0(collapse = "|")
return(rvals)
}) %>% unlist
df01$ref_gt[df01$ref_gt=="0|1"] <- "1|0"
df01$ltgt_to_gt[df01$ltgt_to_gt=="0|1"] <- "1|0"
df01$match <- paste0(df01$ltgt_to_gt == df01$ref_gt)
g1 <- ggplot(df01) +
geom_point(data=df01, aes(x = quality, y=total_reads, color=match), alpha=0.7) +
ggtitle("locityper accuracy by call quality vs total_reads, ") +
labs(color="correct call") ; plot(g1)
ggplot(df01) +
geom_point(data=df01, aes(x=unexpl_reads, y=weight_dist, color=match), alpha=0.7)
ggplot(df01, aes(x=weight_dist, fill=match)) +
geom_histogram(alpha=0.7, position = "identity", aes(y = ..density..))
ggplot(df01, aes(x=unexpl_reads, fill=match)) +
geom_histogram(alpha=0.7, position = "identity", aes(y = ..density..))
df01$log_unexplained_reads <- log(1 + df01$unexpl_reads)
df01$log_weight_dist <- log(1 + df01$weight_dist)
ggplot(df01) +
geom_point(data=df01, aes(x=log_unexplained_reads, y=log_weight_dist, color=match), alpha=0.7)
g2 <- ggplot(df01, aes(x=log_weight_dist, fill=match)) +
geom_histogram(alpha=0.7, position = "identity", aes(y = ..density..)) +
ggtitle("locityper accuracy by log(weight distribution) split by correct/not correct") +
labs(fill="correct gt call") ; plot(g2)
ggplot(df01, aes(x=log_unexplained_reads, fill=match)) +
geom_histogram(alpha=0.7, position = "identity", aes(y = ..density..))
ggsave("C:/docs/aou/locityper/manual_fastas/benchmark_1kg_plot_03.png", plot=g1, width=3200, height=2000, units="px")
ggsave("C:/docs/aou/locityper/manual_fastas/benchmark_1kg_plot_04.png", plot=g2, width=3200, height=2000, units="px")
df01$class <- lapply(seq_down(df01), function(x){
if(df01$ltgt_to_gt[x] == "0|0"){
if(df01$ref_gt[x]=="0|0"){
return("TRUE_NEGATIVE")
} else {
return("FALSE_NEGATIVE")
}
} else {
if(df01$ref_gt[x]=="0|0"){
return("FALSE_POSITIVE")
} else {
return("TRUE_POSITIVE")
}
}
return("NA")
}) %>% unlist()
MY_SENS <- sum(df01$class=="TRUE_POSITIVE")/sum(df01$class=="TRUE_POSITIVE" | df01$class=="FALSE_NEGATIVE")
MY_SPEC <- sum(df01$class=="TRUE_NEGATIVE")/sum(df01$class=="TRUE_NEGATIVE" | df01$class=="FALSE_POSITIVE")
MY_RECALL <- MY_SENS
MY_PRECISION <- sum(df01$class=="TRUE_POSITIVE")/sum(df01$class=="TRUE_POSITIVE" | df01$class=="FALSE_POSITIVE")
MY_F1 <- 2*(MY_PRECISION * MY_RECALL)/(MY_PRECISION + MY_RECALL)
list_by_variant <- lapply(df01$locus %>% u, function(x){
df01[df01$locus==x, ]
})
names(list_by_variant) <- df01$locus %>% u
df_rval <- lapply(list_by_variant, function(x){
print(x$locus[1])
rval <- data.frame(name = x$locus[1],
accuracy = sum(x$match %>% as.logical) / nrow(x),
sensitivity=sum(x$class=="TRUE_POSITIVE")/sum(x$class=="TRUE_POSITIVE" | x$class=="FALSE_NEGATIVE"),
specificity=sum(x$class=="TRUE_NEGATIVE")/sum(x$class=="TRUE_NEGATIVE" | x$class=="FALSE_POSITIVE"),
precision=sum(x$class=="TRUE_POSITIVE")/sum(x$class=="TRUE_POSITIVE" | x$class=="FALSE_POSITIVE"),
n_samples = nrow(x),
stringsAsFactors = FALSE)
rval$F1 <- 2 * (rval$precision[1] * rval$sensitivity[1]) / (rval$precision[1] + rval$sensitivity[1])
return(rval)
}) %>% do.call(rbind, .)
df_rval <- df_rval[order(df_rval$accuracy, decreasing = TRUE), ]
rownames(df_rval) <- seq_down(df_rval)
for(row in 1:nrow(df_rval)){
for(col in 2:ncol(df_rval)){
df_rval[row, col] <- round(df_rval[row, col], 3)
}
}
df_panel <- fread("C:/docs/aou/locityper/220/Locityper_SV_Panel - 1KGSV_YangAnnot.tsv") %>% as.data.frame()
df_rval$GENE <- lapply(df_rval$name, function(x){
temp1 <- df_panel$gene[df_panel$ID==x]
if(length(temp1)==0){
return("")
}
else{
return(temp1)
}
}) %>% unlist
df_rval$notes <- lapply(seq_down(df_rval), function(x){
if(df_rval$sensitivity[x] %>% is.nan){
if(lu(list_by_variant[[df_rval$name[x]]]$ref_gt)==1 & lu(list_by_variant[[df_rval$name[x]]]$ltgt_to_gt)==1 ){
return("only 0|0 in VCF")
}
}
if(df_rval$precision[x] %>% is.nan){
if(lu(list_by_variant[[df_rval$name[[x]]]]$ltgt_to_gt)==1 & all(list_by_variant[[df_rval$name[[x]]]]$ltgt_to_gt=="0|0")){
return("locityper only called 0|0")
}
}
return("")
}) %>% unlist
df_rval$notes <- lapply(seq_down(df_rval), function(x){
n_10 <- sum(df11$has_cram[df11$variant==df_rval$name[x] & df11$gt=="1|0"])
rval <- paste0(n_10, ", ", df_rval$notes[x])
return(rval)
}) %>% unlist
df_rval <- df_rval[order(df_rval$F1, decreasing = TRUE), ]
write.table(df_rval, "C:/docs/aou/locityper/manual_fastas/summary_stats_by_loci.tsv", sep="\t", col.names = TRUE, row.names = FALSE, quote=FALSE)
