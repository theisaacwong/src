df00 <- fread("C:/docs/aou/locityper/608/table.txt", sep="\t") %>% as.data.frame()
df00[1:10, 1:10]
df00 <- fread("C:/docs/aou/locityper/608/table.txt", sep="\t") %>% as.data.frame()
variantToSamples <- HashMap$new()
temp1 <- lapply(seq_down(df00), function(x){
curr_var <- df00$ID[x]
variantToSamples$put(curr_var, HashMap$new())
temp2 <- lapply(4:ncol(df00), function(y){
curr_sample <- colnames(df00)[y]
curr_genotype <- df00[x,y]
variantToSamples$get(curr_var)$put(curr_sample, curr_genotype)
})
})
df10 <- lapply(variantToSamples$keySet(), function(var){
temp1 <- lapply(variantToSamples$get(var)$keySet(), function(samp){
data.frame(variant=var,
sample=samp,
gt=variantToSamples$get(var)$get(samp))
}) %>% do.call(rbind, .) %>% as.data.frame()
return(temp1)
}) %>% do.call(rbind, .)
write.table(df10, "C:/docs/aou/locityper/608/variantToSampleToGT.tsv", sep="\t", col.names = TRUE, row.names = FALSE, quote=FALSE)
df11 <- df10[df10$gt=="1|0", ]
df20 <- fread("C:/docs/aou/locityper/608/manifest.tsv") %>% as.data.frame()
df11$has_cram <- df11$sample %in% df20$SAMPLE
df01 <- fread("C:/docs/aou/locityper/608/locityper_summary_20260612.tsv") %>% as.data.frame()
df01 <- fread("C:/docs/aou/locityper/608/locityper_summary_608_20260619.tsv") %>% as.data.frame()
head(df01)
df01$ref_gt <- lapply(seq_down(df01), function(x){
curr_var <- df01$locus[x]
curr_sample <- df01$sample[x]
if(!variantToSamples$containsKey(curr_var)){return("NA")}
if(variantToSamples$get(curr_var)$containsKey(curr_sample)){
return(variantToSamples$get(curr_var)$get(curr_sample))
} else {
return("NA")
}
}) %>% unlist
df01 <- df01[df01$ref_gt != "NA", ]
df01 <- df01[!grepl("\\.", df01$ref_gt), ]
df01$ltgt_to_gt <- lapply(seq_down(df01), function(x){
rvals <- lapply(unlist(df01$genotype[x] %>% str_split(",")), function(gt){
rval <- "ooblets"
if(gt=="GRCh38"){
rval <- "0"
} else {
which_hap  <- gt %>% str_extract("(?<=\\.).$") %>% as.numeric()
which_samp <- gt %>% str_extract(".*(?=..$)")
# print(paste0(gt,  ": ", which_samp, " ::: ", which_hap))
rval <- unlist(str_split(variantToSamples$get(df01$locus[x])$get(which_samp), "\\|"))[which_hap]
}
return(rval)
}) %>% unlist %>% paste0(collapse = "|")
return(rvals)
}) %>% unlist
df01$ref_gt[df01$ref_gt=="0|1"] <- "1|0"
df01$ltgt_to_gt[df01$ltgt_to_gt=="0|1"] <- "1|0"
df01$match <- paste0(df01$ltgt_to_gt == df01$ref_gt)
g1 <- ggplot(df01) +
geom_point(data=df01, aes(x = quality, y=total_reads, color=match), alpha=0.7) +
ggtitle("locityper accuracy by call quality vs total_reads, ") +
labs(color="correct call") ; # plot(g1)
ggplot(df01) +
geom_point(data=df01, aes(x=unexpl_reads, y=weight_dist, color=match), alpha=0.7)
ggplot(df01, aes(x=weight_dist, fill=match)) +
geom_histogram(alpha=0.7, position = "identity", aes(y = ..density..))
ggplot(df01, aes(x=unexpl_reads, fill=match)) +
geom_histogram(alpha=0.7, position = "identity", aes(y = ..density..))
df01$log_unexplained_reads <- log(1 + df01$unexpl_reads)
df01$log_weight_dist <- log(1 + df01$weight_dist)
ggplot(df01) +
geom_point(data=df01, aes(x=log_unexplained_reads, y=log_weight_dist, color=match), alpha=0.7)
g2 <- ggplot(df01, aes(x=log_weight_dist, fill=match)) +
geom_histogram(alpha=0.7, position = "identity", aes(y = ..density..)) +
ggtitle("locityper accuracy by log(weight distribution) split by correct/not correct") +
labs(fill="correct gt call") ; # plot(g2)
ggplot(df01, aes(x=log_unexplained_reads, fill=match)) +
geom_histogram(alpha=0.7, position = "identity", aes(y = ..density..))
ggsave("C:/docs/aou/locityper/608/benchmark_1kg_plot_03.png", plot=g1, width=3200, height=2000, units="px")
ggsave("C:/docs/aou/locityper/608/benchmark_1kg_plot_04.png", plot=g2, width=3200, height=2000, units="px")
g1
